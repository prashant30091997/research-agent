   "cell_type": "markdown",
   "metadata": {},
   "source": ["# 🧬 ResearchAgent v5.0 — Backend Server\n\n**Run these cells in order to start the backend.**\n\n1. Cell 1: Clone repo + install dependencies\n2. Cell 2: Set your API keys\n3. Cell 3: Start the server (keep this running)\n\nThen open your frontend at: `https://YOUR_USERNAME.github.io/research-agent/`\n\nPaste the ngrok URL shown below into your frontend Settings.\n\n---"]
  },
  {
   "cell_type": "code",
   "metadata": {"id": "setup"},
   "source": ["# Fresh clone every time (picks up latest changes)\n!rm -rf /content/research-agent\n!git clone https://github.com/prashant30091997/research-agent.git\n%cd /content/research-agent/backend\n!pip install -q fastapi uvicorn==0.29.0 httpx python-dotenv pydantic pyngrok\nprint('✅ Ready — fresh code from GitHub')"] "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {"id": "keys"},
   "source": ["# ═══ CELL 2: Set your API keys ═══\n# Option A: Enter directly\nimport os\nos.environ['ANTHROPIC_API_KEY'] = ''  # sk-ant-api03-...\nos.environ['GOOGLE_API_KEY'] = ''      # AIzaSy...\nos.environ['SCOPUS_API_KEY'] = ''      # (optional) Elsevier key\nos.environ['DEFAULT_MODEL'] = 'claude-sonnet-4-20250514'\n\n# Option B: Load from Google Drive (uncomment below)\n# from google.colab import drive\n# drive.mount('/content/drive')\n# import json\n# keys = json.load(open('/content/drive/MyDrive/research_agent_api_keys.json'))\n# os.environ['ANTHROPIC_API_KEY'] = keys.get('anthropic', '')\n# os.environ['GOOGLE_API_KEY'] = keys.get('google', '')\n# os.environ['SCOPUS_API_KEY'] = keys.get('scopus', '')\n\nprint('🔑 Keys set:')\nprint(f\"  Anthropic: {'✅' if os.environ.get('ANTHROPIC_API_KEY') else '❌'}\")\nprint(f\"  Google:    {'✅' if os.environ.get('GOOGLE_API_KEY') else '❌'}\")\nprint(f\"  Scopus:    {'✅' if os.environ.get('SCOPUS_API_KEY') else '⏭️ Optional'}\")\nprint(f\"  Model:     {os.environ.get('DEFAULT_MODEL', 'not set')}\")"],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {"id": "server"},
   "source": ["# ═══ CELL 3: Start the server with public URL ═══\n# Get free ngrok auth token at: https://ngrok.com/signup\n# Dashboard → Your Authtoken → Copy\n\nNGROK_TOKEN = ''  # Paste your ngrok auth token here\n\nfrom pyngrok import ngrok\nimport nest_asyncio\nnest_asyncio.apply()\n\nif NGROK_TOKEN:\n    ngrok.set_auth_token(NGROK_TOKEN)\n\n# Start ngrok tunnel\npublic_url = ngrok.connect(8000)\nprint(f'\\n{\"=\"*60}')\nprint(f'🌐 PUBLIC URL: {public_url}')\nprint(f'{\"=\"*60}')\nprint(f'\\n📋 Copy this URL and paste it in your ResearchAgent frontend:')\nprint(f'   Settings → Backend URL → {public_url}')\nprint(f'\\n🖥️  Or open directly: {public_url}/api/health')\nprint(f'{\"=\"*60}\\n')\n\n# Start FastAPI server (this blocks — keep the cell running)\nimport uvicorn\nuvicorn.run('main:app', host='0.0.0.0', port=8000)"],
   "execution_count": null,
   "outputs": []
  },
